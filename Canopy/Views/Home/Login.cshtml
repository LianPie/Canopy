@namespace Canopy.Resources
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization

@inject IViewLocalizer V
@inject IHtmlLocalizer<SharedResources> SR

@section Head
{
    <link href="~/css/loginstyle.css" rel="stylesheet" />

    <style>
        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid #f3f3f3;
            border-top: 3px solid #3498db;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-right: 8px;
        }

        @@keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        .login-btn.loading {
            opacity: 0.7;
            cursor: not-allowed;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
}

<div class="login-container">
    <div class="login-card">
        <div class="avatar-container">
            <div class="avatar-circle">
                <i class="fa-solid fa-leaf"></i>

            </div>
        </div>
        @Html.AntiForgeryToken()
        <div class="input-group">
            <div class="input-box">
                <i class="fa-solid fa-user"></i>
                <input type="text" id="username" placeholder="@V["11_LoginUname"]">
            </div>
            <div class="input-box">
                <i class="fa-solid fa-lock"></i>
                <input type="password" id="passwordField" placeholder="@V["12_LoginPass"]">
                <button type="button" id="togglePassword" class="toggle-btn" title="Show/Hide Password">
                    <i class="fa-solid fa-eye-slash" id="lockIcon"></i>
                </button>
            </div>
        </div>

        <div class="options">
            <label class="checkbox-wrapper">
                <input type="checkbox" id="RememberMe">
                <div class="checkmark">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M20 6L9 17L4 12" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        </path>
                    </svg>
                </div>
                <span class="label">@V["13_RememberMe"]</span>


            </label>
            <a href="#">@V["14_ForgotPassword"]</a>
        </div>

        <button class="login-btn" id="loginBtn">@SR["LoginBtn"]</button>
        <p class="switch-mode">@V["15_NoAccount"]<a href="~/home/Signup"> @V["16_SignUp"] </a></p>
    </div>
</div>


@section Scripts {
    <script>
        const togglePassword = document.querySelector('#togglePassword');
        const passwordField = document.querySelector('#passwordField');
        const lockIcon = document.querySelector('#lockIcon');

        togglePassword.addEventListener('click', function () {
            const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordField.setAttribute('type', type);

            if (type === 'text') {
                lockIcon.classList.remove('fa-eye-slash');
                lockIcon.classList.add('fa-eye');
                this.classList.add('is-visible');
            } else {
                lockIcon.classList.remove('fa-eye');
                lockIcon.classList.add('fa-eye-slash');
                this.classList.remove('is-visible');
            }
        });

        const vmessages = {
            requiredFields: '@V["RequiredFields"]',
            error400: '@V["Error400"]',
            error403: '@V["Error403"]',
            error500: '@V["Error500"]',
            errorGeneric: '@V["ErrorGeneric"]',
            InvalidCred: '@V["17_InvalidCred"]',
        };

        $(document).ready(function() {
            $('#loginBtn').click(function(e) {
                e.preventDefault();

                const loginData = {
                    Username: $('#username').val(),
                    Password: $('#passwordField').val(),
                    RememberMe: $('#RememberMe').is(':checked')
                };

                if (!loginData.Username || !loginData.Password) {
                    toastr.warning(vmessages.requiredFields);
                    return;
                }

                const $btn = $(this);
                const originalText = $btn.text();
                $btn.html('<span class="loading-spinner"></span> Logging in...').addClass('loading').prop('disabled', true);
               let token= $("input[name='__RequestVerificationToken']").val()
                $.ajax({
                    url: '/Home/Login',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(loginData),
                       headers: {
                        'RequestVerificationToken': token
                        },
                    xhrFields: {
                        withCredentials: true
                    },
                        success: function(response) {
                            toastr.success(response.message.value);
                        setTimeout(function() {
                            window.location.href = '/dashboard';
                        }, 1500);
                    },
                    error: function(xhr) {
                        $btn.html(originalText).removeClass('loading').prop('disabled', false);

                        if (xhr.status === 401) {
                            if (xhr.responseJSON) {
                                if (xhr.responseJSON.errors) {
                                    $.each(xhr.responseJSON.errors, function(field, messages) {
                                        toastr.error(messages[0]);
                                    });
                                }
                                else if (xhr.responseJSON.message) {
                                    toastr.error(xhr.responseJSON.message);
                                }
                                else {
                                    toastr.error(vmessages.InvalidCred);
                                }
                            } else {
                                toastr.error(vmessages.InvalidCred);
                            }
                        }
                        else if (xhr.status === 400) {
                            const response = xhr.responseJSON;
                            if (response && response.errors) {
                                $.each(response.errors, function(field, messages) {
                                    toastr.error(messages[0]);
                                });
                            } else if (response && response.message) {
                                toastr.error(response.message);
                            } else {
                                toastr.error(vmessages.error400);
                            }
                        }
                        else if (xhr.status === 403) {
                            const response = xhr.responseJSON;
                            if (response && response.message) {
                                toastr.error(response.message);
                            } else {
                                toastr.error(vmessages.error403);
                            }
                        }
                        else if (xhr.status === 500) {
                            toastr.error(vmessages.error500);
                        }
                        else {
                            toastr.error(vmessages.errorGeneric);
                        }
                    }
                });
            });
        });
    </script>

}
