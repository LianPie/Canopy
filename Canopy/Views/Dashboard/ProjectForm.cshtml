@namespace Canopy.Resources
@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization

@model Canopy.Models.ProjectViewModel


@inject IViewLocalizer _localizer

@{
    Layout = "~/views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = Model.IsEdit ? _localizer["EditProjectTitle"] : _localizer["NewProjectTitle"];
}

<!-- Header with Submit -->
<div class="toolbar d-flex justify-content-between mb-5">
    <h3>@ViewData["Title"]</h3>
    <div class="d-flex gap-2">
        <a href="/Dashboard/Projects" class="btn btn-secondary">
            @_localizer["Cancel"]
        </a>
        <button form="projectForm" class="btn btn-primary" onclick="">
            <i class="ki-outline ki-check-circle fs-2"></i> @_localizer["Save"]
        </button>
    </div>
</div>

<form id="projectForm">
    <input type="hidden" id="projectId" value="@Model.Id" />


    <div class="row g-5">

        <!-- LEFT: Tasks Section -->
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5>@_localizer["Tasks"]</h5>
                    <button type="button" class="btn btn-sm btn-light-primary" id="addTaskBtn">
                        <i class="ki-outline ki-plus fs-2"></i> @_localizer["AddTask"]
                    </button>
                </div>
                <div class="card-body p-0">
                    <div id="taskList" class="p-5" style="max-height: 500px; overflow-y: auto;">
                        <!-- Tasks added dynamically or loaded for edit -->
                        @if (Model.Tasks != null)
                        {
                            foreach (var task in Model.Tasks)
                            {
                                <div class="task-item border rounded p-3 mb-3">
                                    <div class="d-flex justify-content-between mb-2">
                                        <input type="text" class="task-id" value="@task.Id" hidden />
                                        <input type="text" class="form-control form-control-sm task-title"
                                               placeholder="@_localizer["TaskTitle"]" value="@task.Title" />
                                        <button type="button" class="btn btn-sm btn-icon btn-light-danger remove-task ms-2 flex-shrink-0">
                                            <i class="ki-outline ki-trash fs-4"></i>
                                        </button>
                                    </div>
                                    <input type="text" class="form-control form-control-sm task-desc mb-2"
                                           placeholder="@_localizer["Description"]" value="@task.Description" />
                                    <input type="text" class="form-control form-control-sm task-deadline persian-date-input"
                                           value="@task.DeadLine" />
                                    @if (Model.IsEdit)
                                    {
                                        <div class="form-check mt-2">
                                            <input class="form-check-input task-status" type="checkbox"
                                                   @(task.Status ? "checked" : "") />
                                            <label class="form-check-label">@_localizer["Completed"]</label>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                    <p id="noTasksMsg" class="text-muted text-center py-5 @(Model.Tasks?.Count > 0 ? "d-none" : "")">
                        @_localizer["NoTasksYet"]
                    </p>
                </div>
            </div>
        </div>

        <!-- RIGHT: Project Details -->
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h5>@_localizer["ProjectDetails"]</h5>
                </div>
                <div class="card-body">
                    <div class="mb-5">
                        <label class="form-label required">@_localizer["TitleColumn"]</label>
                        <input type="text" id="projectTitle" class="form-control"
                               value="@Model.Title" required />
                    </div>

                    <div class="mb-5">
                        <label class="form-label">@_localizer["Description"]</label>
                        <textarea id="projectDesc" class="form-control" rows="4">@Model.Description</textarea>
                    </div>

                    <div class="mb-5">
                        <label class="form-label">@_localizer["DeadlineColumn"]</label>
                        <input type="text" class="form-control persian-date-input"
                               id="projectDeadline"
                               name="Deadline"
                               data-gregorian-value="@Model.Deadline?.ToString("yyyy-MM-dd")" 
                               value="@Model.Deadline" />
                    </div>

                    @if (Model.IsEdit)
                    {
                        <div class="mb-5">
                            <label class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="projectActive"
                                       @(Model.Status ? "checked" : "") />
                                <span class="form-check-label">@_localizer["done"]</span>
                            </label>
                        </div>
                    }

                    <div class="text-muted small">
                        <i class="ki-outline ki-calendar fs-6 me-1"></i>
                        @_localizer["Created"]: @Model.DateCreated.ToString("MMM dd, yyyy")
                    </div>
                </div>
            </div>

            <!-- Later: Group & Members Section -->
            <!-- <div class="card mt-5">
                <div class="card-header">
                    <h5>@_localizer["GroupAndMembers"]</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Coming soon...</p>
                </div>
            </div> -->
        </div>
    </div>
</form>

@section Scripts {
    <script>
        
        var projectId = $('#projectId').val();
        
        // Submit form4        
        $('#projectForm').submit(function(e) {
            e.preventDefault();
            submitProject();
        });

        $(document).ready(function() {
            var isEdit = projectId !== '';


            // Add task button
            $('#addTaskBtn').click(function() {
                addTaskRow();
            });

            // Remove task button (delegate for dynamic elements)
            $(document).on('click', '.remove-task', function() {
                $(this).closest('.task-item').remove();
                toggleNoTasksMessage();
            });

        });

        const titlePlaceholder = '@_localizer["TaskTitle"]';
        const dscPlaceholder = '@_localizer["Description"]';


        function addTaskRow(title, desc, deadline, status) {
                var statusHtml = $('#projectId').val() ? `
                    <div class="form-check mt-2">
                        <input class="form-check-input task-status" type="checkbox" ${status ? 'checked' : ''} />
                        <label class="form-check-label">@_localizer["Completed"]</label>
                    </div>` : '';

                // 1. Convert string template to jQuery object
                var $newRow = $(`
                    <div class="task-item border rounded p-3 mb-3">
                        <div class="d-flex justify-content-between mb-2">
                            <input type="hidden" class="task-id" value="0" />
                            <input type="text" class="form-control form-control-sm task-title"
                                   placeholder="${titlePlaceholder}" value="${title || ''}" />
                            <button type="button" class="btn btn-sm btn-icon btn-light-danger remove-task">
                                <i class="ki-outline ki-trash fs-4"></i>
                            </button>
                        </div>
                        <input type="text" class="form-control form-control-sm task-desc mb-2"
                               placeholder="${dscPlaceholder}" value="${desc || ''}" />
                        <input type="text" class="form-control form-control-sm task-deadline persian-date-input"
                               value="${deadline || ''}" />
                        ${statusHtml}
                    </div>`);

                // 2. Run initialization specifically targeting this row container
                initPersianDatepickers($newRow);

                $('#taskList').append($newRow);
                toggleNoTasksMessage();
            }

        function toggleNoTasksMessage() {
            var count = $('#taskList .task-item').length;
            $('#noTasksMsg').toggleClass('d-none', count > 0);
        }



        function collectTasks() {
            var tasks = [];
            $('#taskList .task-item').each(function() {
                tasks.push({
                    Id: parseInt($(this).find('.task-id').val()) || 0,
                    Title: $(this).find('.task-title').val(),
                    Description: $(this).find('.task-desc').val(),
                    DeadLine: normalizeToGregorian($(this).find('.task-deadline').val()),
                    Status: $(this).find('.task-status').is(':checked')
                });
            });
            return tasks;
        }

        function submitProject() {
            var deadlineRaw = $('#projectDeadline').val();

            var data = {
                Title: $('#projectTitle').val(),
                Description: $('#projectDesc').val(),
                Deadline: normalizeToGregorian(deadlineRaw),
                Status: $('#projectActive').is(':checked') ?? false,
                Group: null,
                Tasks: collectTasks()
            };


            var url = projectId ? '/api/projects/' + projectId : '/api/projects';
            var method = projectId ? 'PUT' : 'POST';
            $.ajax({
                url: url,
                type: method,
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function() {
                    toastr.success('@_localizer["savedSuccessfully"]');
                    setTimeout(function() {
                        window.location.href = projectId ? '/Dashboard/ProjectForm/' + projectId : '/Dashboard/Projects';
                    }, 2000);

                },
                error: function(xhr) {
                    toastr.error('@_localizer["FailedSave"]' + (xhr.responseJSON?.message || ''));
                }
            });
        }

        
    </script>
}