@namespace Canopy.Resources
@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization


@inject IViewLocalizer _localizer

@{
    Layout = "~/views/Shared/_DashboardLayout.cshtml";
}

<style>
    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 16px;
    }

    .project-card {
        background: var(--bs-card-bg, #fff);
        border: 1px solid var(--bs-border-color, #e4e6ef);
        border-radius: 14px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        transition: box-shadow 0.15s, transform 0.15s;
        position: relative;
        overflow: hidden;
    }

    .project-card:hover {
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        transform: translateY(-2px);
    }

    .project-card-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: var(--bs-light-primary, #f1f5ff);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .project-card-title {
        font-weight: 700;
        font-size: 15px;
        line-height: 1.3;
        word-break: break-word;
    }

    .project-card-meta {
        display: flex;
        flex-direction: column;
        gap: 5px;
        font-size: 12px;
        color: var(--bs-gray-500);
    }

    .project-card-meta span {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .project-card-progress {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .project-card-progress .progress {
        height: 5px;
        border-radius: 3px;
    }

    .project-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 4px;
    }

    .project-card-actions {
        display: flex;
        gap: 4px;
        opacity: 0;
        transition: opacity 0.15s;
    }

    .project-card:hover .project-card-actions { opacity: 1; }

    /* overdue accent */
    .project-card.overdue::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: var(--bs-danger);
        border-radius: 14px 14px 0 0;
    }

    .project-card.active-project::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: var(--bs-primary);
        border-radius: 14px 14px 0 0;
    }
</style>

<div class="toolbar d-flex justify-content-between align-items-center mb-5">
    <h3 class="mb-0">@_localizer["TableTitle"]</h3>
    <a href="/Dashboard/ProjectForm" class="btn btn-primary btn-sm">
        <i class="ki-outline ki-plus fs-4"></i> @_localizer["NewProject"]
    </a>
</div>

<!-- Grid + sentinel -->
<div class="projects-grid" id="projectsGrid"></div>
<div id="gridSentinel" style="height:1px"></div>

<!-- Skeleton template (hidden) -->
<div id="skeletonTpl" style="display:none">
    <div class="project-card" style="pointer-events:none">
        <div class="d-flex align-items-start gap-3">
            <div class="sk-box" style="width:44px;height:44px;border-radius:12px;flex-shrink:0"></div>
            <div class="flex-grow-1">
                <div class="sk-line" style="width:70%;height:14px;border-radius:4px;margin-bottom:6px"></div>
                <div class="sk-line" style="width:45%;height:11px;border-radius:4px"></div>
            </div>
        </div>
        <div class="sk-line" style="width:55%;height:11px;border-radius:4px"></div>
        <div class="sk-line" style="width:100%;height:5px;border-radius:3px"></div>
        <div class="d-flex justify-content-between">
            <div class="sk-line" style="width:50px;height:18px;border-radius:6px"></div>
        </div>
    </div>
</div>

<style>
    .sk-box, .sk-line {
        background: var(--bs-gray-200);
        animation: sk-pulse 1.4s ease-in-out infinite;
    }
    @@keyframes sk-pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
</style>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-danger"><i class="ki-outline ki-trash fs-2 me-2"></i>@_localizer["DeleteTitle"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2">
                @_localizer["DeleteProjectConfirm"] "<strong><span id="deleteProjectTitle"></span></strong>"?
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">@_localizer["Cancel"]</button>
                <button id="confirmDeleteBtn" class="btn btn-danger">@_localizer["Delete"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $("#projectsMenu").addClass("active");

    const L = {
        noProjects:    '@_localizer["NoProjects"]',
        addFirst:      '@_localizer["AddFirstProject"]',
        tasks:         '@_localizer["Tasks"]',
        completed:     '@_localizer["Completed"]',
        active:        '@_localizer["Active"]',
        pending:       '@_localizer["Pendig"]',
        overdue:       '@_localizer["Overdue"]',
        edit:          '@_localizer["Edit"]',
        del:           '@_localizer["Delete"]',
        deleteSuccess: '@_localizer["DeleteSuccess"]',
        deleteError:   '@_localizer["DeleteError"]',
    };

    const PAGE_SIZE = 12;
    let page = 1, loading = false, hasMore = true;

    const grid     = document.getElementById('projectsGrid');
    const sentinel = document.getElementById('gridSentinel');
    const skelTpl  = document.getElementById('skeletonTpl');

    // ── Render a project card ─────────────────────────────────
    function cardHtml(p) {
        const total   = p.tasks ? p.tasks.length : 0;
        const done    = p.tasks ? p.tasks.filter(t => t.status).length : 0;
        const pct     = total ? Math.round(done / total * 100) : 0;
        const now     = new Date(); now.setHours(0,0,0,0);
        const overdue = p.deadline && new Date(p.deadline) < now && p.status;
        const cls     = overdue ? 'overdue' : p.status ? 'active-project' : '';
        const dlStr   = p.deadline ? new Date(p.deadline).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'}) : '';

        return `
        <div class="project-card ${cls}" id="project_${p.id}">
            <div class="d-flex align-items-start gap-3">
                <div class="project-card-icon">
                    <i class="ki-outline ki-element-11 fs-2 text-primary"></i>
                </div>
                <div class="flex-grow-1 overflow-hidden">
                    <div class="project-card-title text-truncate">${escHtml(p.title)}</div>
                    ${p.description ? `<div class="text-muted fs-7 text-truncate mt-1">${escHtml(p.description)}</div>` : ''}
                </div>
            </div>
            <div class="project-card-meta">
                <span><i class="ki-outline ki-check-circle fs-6"></i> ${done} / ${total} ${L.tasks}</span>
                ${dlStr ? `<span class="${overdue ? 'text-danger fw-semibold' : ''}">
                    <i class="ki-outline ki-calendar fs-6"></i> ${dlStr}
                    ${overdue ? `<span class="badge badge-light-danger fs-9 ms-1">${L.overdue}</span>` : ''}
                </span>` : ''}
                ${p.group ? `<span><i class="ki-outline ki-people fs-6"></i> ${escHtml(p.group.title)}</span>` : ''}
            </div>
            ${total > 0 ? `
            <div class="project-card-progress">
                <div class="progress"><div class="progress-bar ${pct===100?'bg-success':'bg-primary'}" style="width:${pct}%"></div></div>
                <small class="text-muted">${pct}% ${L.completed}</small>
            </div>` : ''}
            <div class="project-card-footer">
                <span class="badge badge-light-${p.status ? 'success' : 'warning'} fs-8">${p.status ? L.active : L.pending}</span>
                <div class="project-card-actions">
                    <a href="/Dashboard/ProjectForm?id=${p.id}" class="btn btn-xs btn-icon btn-light-primary" title="${L.edit}">
                        <i class="ki-outline ki-pencil fs-5"></i>
                    </a>
                    <button class="btn btn-xs btn-icon btn-light-danger" title="${L.del}"
                            onclick="showDeleteModal(${p.id}, '${escJs(p.title)}')">
                        <i class="ki-outline ki-trash fs-5"></i>
                    </button>
                </div>
            </div>
        </div>`;
    }

    // ── Skeleton helpers ──────────────────────────────────────
    function showSkeletons(n) {
        for (let i = 0; i < n; i++) {
            const el = skelTpl.firstElementChild.cloneNode(true);
            el.id = 'sk-' + i;
            grid.appendChild(el);
        }
    }
    function removeSkeletons() {
        grid.querySelectorAll('[id^="sk-"]').forEach(el => el.remove());
    }

    // ── Fetch next page ───────────────────────────────────────
    function loadPage() {
        if (loading || !hasMore) return;
        loading = true;
        showSkeletons(PAGE_SIZE);

        $.get(`/api/Projects/paged?page=${page}&pageSize=${PAGE_SIZE}`, function (res) {
            removeSkeletons();
            hasMore = res.hasMore;

            if (page === 1 && res.items.length === 0) {
                grid.innerHTML = `
                    <div class="d-flex flex-column align-items-center justify-content-center py-20 text-muted" style="grid-column:1/-1">
                        <i class="ki-outline ki-element-11 fs-2tx mb-4"></i>
                        <p class="mb-4">${L.noProjects}</p>
                        <a href="/Dashboard/ProjectForm" class="btn btn-sm btn-primary">${L.addFirst}</a>
                    </div>`;
                observer.disconnect();
            } else {
                res.items.forEach(p => grid.insertAdjacentHTML('beforeend', cardHtml(p)));
                page++;
                if (!hasMore) observer.disconnect();
            }
        }).always(() => { loading = false; });
    }

    // ── Intersection Observer ─────────────────────────────────
    const observer = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) loadPage();
    }, { rootMargin: '200px' });

    observer.observe(sentinel);

    // ── Utils ─────────────────────────────────────────────────
    function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function escJs(s)   { return String(s).replace(/\\/g,'\\\\').replace(/'/g,"\\'"); }

    // ── Delete ────────────────────────────────────────────────
    function showDeleteModal(id, title) {
        $('#deleteProjectTitle').text(title);
        $('#confirmDeleteBtn').off('click').on('click', () => deleteProject(id));
        $('#deleteModal').modal('show');
    }

    function deleteProject(id) {
        $.ajax({
            url: '/api/Projects/' + id, type: 'DELETE',
            success: function () {
                $(`#project_${id}`).remove();
                $('#deleteModal').modal('hide');
                toastr.success(L.deleteSuccess);
            },
            error: () => toastr.error(L.deleteError)
        });
    }
</script>
}
