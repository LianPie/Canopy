@namespace Canopy.Resources
@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization

@using Canopy.Models
@model List<Project>

@inject IViewLocalizer _localizer

@{
    Layout = "~/views/Shared/_DashboardLayout.cshtml";
}

<style>
    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 16px;
    }

    .project-card {
        background: var(--bs-card-bg, #fff);
        border: 1px solid var(--bs-border-color, #e4e6ef);
        border-radius: 14px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        transition: box-shadow 0.15s, transform 0.15s;
        position: relative;
        overflow: hidden;
    }

    .project-card:hover {
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        transform: translateY(-2px);
    }

    .project-card-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: var(--bs-light-primary, #f1f5ff);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .project-card-title {
        font-weight: 700;
        font-size: 15px;
        line-height: 1.3;
        word-break: break-word;
    }

    .project-card-meta {
        display: flex;
        flex-direction: column;
        gap: 5px;
        font-size: 12px;
        color: var(--bs-gray-500);
    }

    .project-card-meta span {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .project-card-progress {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .project-card-progress .progress {
        height: 5px;
        border-radius: 3px;
    }

    .project-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 4px;
    }

    .project-card-actions {
        display: flex;
        gap: 4px;
        opacity: 0;
        transition: opacity 0.15s;
    }

    .project-card:hover .project-card-actions { opacity: 1; }

    /* overdue accent */
    .project-card.overdue::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: var(--bs-danger);
        border-radius: 14px 14px 0 0;
    }

    .project-card.active-project::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: var(--bs-primary);
        border-radius: 14px 14px 0 0;
    }
</style>

<div class="toolbar d-flex justify-content-between align-items-center mb-5">
    <h3 class="mb-0">@_localizer["TableTitle"]</h3>
    <a href="/Dashboard/ProjectForm" class="btn btn-primary btn-sm">
        <i class="ki-outline ki-plus fs-4"></i> @_localizer["NewProject"]
    </a>
</div>

@if (!Model.Any())
{
    <div class="d-flex flex-column align-items-center justify-content-center py-20 text-muted">
        <i class="ki-outline ki-element-11 fs-2tx mb-4"></i>
        <p class="mb-4">@_localizer["NoProjects"]</p>
        <a href="/Dashboard/ProjectForm" class="btn btn-sm btn-primary">@_localizer["AddFirstProject"]</a>
    </div>
}
else
{
    <div class="projects-grid">
        @foreach (var project in Model)
        {
            var totalTasks = project.Tasks?.Count ?? 0;
            var doneTasks  = project.Tasks?.Count(t => t.Status) ?? 0;
            var pct        = totalTasks > 0 ? (int)Math.Round((double)doneTasks / totalTasks * 100) : 0;
            var isOverdue  = project.Deadline.HasValue && project.Deadline.Value.Date < DateTime.Now.Date && project.Status;

            <div class="project-card @(isOverdue ? "overdue" : project.Status ? "active-project" : "")" id="project_@project.Id">

                <div class="d-flex align-items-start gap-3">
                    <div class="project-card-icon">
                        <i class="ki-outline ki-element-11 fs-2 text-primary"></i>
                    </div>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="project-card-title text-truncate">@project.Title</div>
                        @if (!string.IsNullOrEmpty(project.Description))
                        {
                            <div class="text-muted fs-7 text-truncate mt-1">@project.Description</div>
                        }
                    </div>
                </div>

                <div class="project-card-meta">
                    <span>
                        <i class="ki-outline ki-check-circle fs-6"></i>
                        @doneTasks / @totalTasks @_localizer["Tasks"]
                    </span>
                    @if (project.Deadline.HasValue)
                    {
                        <span class="@(isOverdue ? "text-danger fw-semibold" : "")">
                            <i class="ki-outline ki-calendar fs-6"></i>
                            @project.Deadline.Value.ToString("MMM dd, yyyy")
                            @if (isOverdue)
                            {
                                <span class="badge badge-light-danger fs-9 ms-1">@_localizer["Overdue"]</span>
                            }
                        </span>
                    }
                    @if (project.Group != null)
                    {
                        <span>
                            <i class="ki-outline ki-people fs-6"></i>
                            @project.Group.Title
                        </span>
                    }
                </div>

                @if (totalTasks > 0)
                {
                    <div class="project-card-progress">
                        <div class="progress">
                            <div class="progress-bar @(pct == 100 ? "bg-success" : "bg-primary")" style="width:@pct%"></div>
                        </div>
                        <small class="text-muted">@pct% @_localizer["Completed"]</small>
                    </div>
                }

                <div class="project-card-footer">
                    @if (project.Status)
                    {
                        <span class="badge badge-light-success fs-8">@_localizer["Active"]</span>
                    }
                    else
                    {
                        <span class="badge badge-light-warning fs-8">@_localizer["Pendig"]</span>
                    }
                    <div class="project-card-actions">
                        <a href="/Dashboard/ProjectForm?id=@project.Id"
                           class="btn btn-xs btn-icon btn-light-primary"
                           title="@_localizer["Edit"]">
                            <i class="ki-outline ki-pencil fs-5"></i>
                        </a>
                        <button class="btn btn-xs btn-icon btn-light-danger"
                                title="@_localizer["Delete"]"
                                onclick="showDeleteModal(@project.Id, '@project.Title.Replace("'", "\\'")')">
                            <i class="ki-outline ki-trash fs-5"></i>
                        </button>
                    </div>
                </div>

            </div>
        }
    </div>
}

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-danger"><i class="ki-outline ki-trash fs-2 me-2"></i>@_localizer["DeleteTitle"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2">
                @_localizer["DeleteProjectConfirm"] "<strong><span id="deleteProjectTitle"></span></strong>"?
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">@_localizer["Cancel"]</button>
                <button id="confirmDeleteBtn" class="btn btn-danger">@_localizer["Delete"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $("#projectsMenu").addClass("active");

        function showDeleteModal(id, title) {
            $('#deleteProjectTitle').text(title);
            $('#confirmDeleteBtn').off('click').on('click', () => deleteProject(id));
            $('#deleteModal').modal('show');
        }

        function deleteProject(id) {
            $.ajax({
                url: '/api/Projects/' + id,
                type: 'DELETE',
                success: function () {
                    $(`#project_${id}`).remove();
                    $('#deleteModal').modal('hide');
                    toastr.success('@_localizer["DeleteSuccess"]');
                },
                error: function () {
                    toastr.error('@_localizer["DeleteError"]');
                }
            });
        }
    </script>
}
