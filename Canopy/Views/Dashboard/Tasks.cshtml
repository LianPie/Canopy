@namespace Canopy.Resources
@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization


@inject IViewLocalizer _localizer

@{
    Layout = "~/views/Shared/_DashboardLayout.cshtml";
}

<style>
    .date-strip-wrapper {
        position: relative;
    }

    .date-strip {
        display: flex;
        gap: 8px;
        overflow-x: auto;
        scroll-behavior: smooth;
        padding: 4px 2px 8px;
        scrollbar-width: none;
    }

    .date-strip::-webkit-scrollbar { display: none; }

    .date-chip {
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 8px 14px;
        border-radius: 12px;
        cursor: pointer;
        border: 2px solid transparent;
        background: var(--bs-gray-100);
        transition: all 0.15s ease;
        min-width: 56px;
        user-select: none;
    }

    .date-chip:hover { background: var(--bs-gray-200); }

    .date-chip.active {
        background: var(--bs-primary);
        color: #fff;
    }

    .date-chip .chip-day {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        opacity: 0.7;
    }

    .date-chip .chip-date {
        font-size: 18px;
        font-weight: 700;
        line-height: 1.2;
    }

    .date-chip .chip-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--bs-primary);
        margin-top: 4px;
    }

    .date-chip.active .chip-dot { background: rgba(255,255,255,0.7); }
    .date-chip.active .chip-day { opacity: 0.8; }

    .task-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid var(--bs-gray-200);
    }

    .task-item:last-child { border-bottom: none; }

    .task-check {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 2px solid var(--bs-gray-400);
        flex-shrink: 0;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s;
    }

    .task-check.done {
        background: var(--bs-success);
        border-color: var(--bs-success);
    }

    .task-check.done::after {
        content: '';
        width: 5px;
        height: 9px;
        border: 2px solid #fff;
        border-top: none;
        border-left: none;
        transform: rotate(45deg) translateY(-1px);
    }

    .task-title.done { text-decoration: line-through; opacity: 0.5; }

    .task-meta { font-size: 12px; color: var(--bs-gray-500); }

    .task-actions { margin-left: auto; display: flex; gap: 4px; opacity: 0; transition: opacity 0.15s; }
    .task-item:hover .task-actions { opacity: 1; }

    .section-header {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--bs-gray-500);
        margin: 20px 0 8px;
    }

    .tasks-skeleton .sk-line {
        height: 14px;
        border-radius: 4px;
        background: var(--bs-gray-200);
        animation: sk-pulse 1.4s ease-in-out infinite;
        margin-bottom: 10px;
    }

    @@keyframes sk-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }

    .empty-day {
        text-align: center;
        padding: 40px 0;
        color: var(--bs-gray-400);
    }

    .empty-day i { font-size: 2.5rem; display: block; margin-bottom: 8px; }

    .collapsible-section {
        border: 1px solid var(--bs-border-color, #e4e6ef);
        border-radius: 12px;
        margin-bottom: 12px;
        overflow: hidden;
    }

    .collapsible-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        cursor: pointer;
        user-select: none;
        background: var(--bs-card-bg, #fff);
        transition: background 0.15s;
    }

    .collapsible-header:hover { background: var(--bs-tertiary-bg); }

    .collapsible-title {
        display: flex;
        align-items: center;
        font-weight: 600;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--bs-gray-600);
    }

    .collapsible-chevron {
        transition: transform 0.2s;
        color: var(--bs-gray-400);
    }

    .collapsible-chevron.open { transform: rotate(180deg); }

    .collapsible-body {
        border-top: 1px solid var(--bs-border-color, #e4e6ef);
        background: var(--bs-card-bg, #fff);
        overflow: hidden;
        max-height: 0;
        opacity: 0;
        transition: max-height 0.3s ease, opacity 0.25s ease;
    }

    .collapsible-body.open {
        max-height: 2000px;
        opacity: 1;
        transition: max-height 0.4s ease, opacity 0.3s ease;
    }

    .load-more-btn {
        display: block;
        width: 100%;
        padding: 10px;
        border: none;
        background: none;
        color: var(--bs-primary);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        border-top: 1px solid var(--bs-border-color, #e4e6ef);
        transition: background 0.15s;
    }

    .load-more-btn:hover { background: var(--bs-tertiary-bg); }

    @@keyframes fadeSlideIn {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .task-item {
        animation: fadeSlideIn 0.2s ease both;
    }
</style>

<div class="toolbar d-flex justify-content-between align-items-center mb-5">
    <h3 class="mb-0">@_localizer["TableTitle"]</h3>
    <a href="/Dashboard/TaskForm" class="btn btn-primary btn-sm">
        <i class="ki-outline ki-plus fs-4"></i> @_localizer["NewTaskTitle"]
    </a>
</div>

<!-- Date strip -->
<div class="date-strip-wrapper mb-4">
    <div class="date-strip" id="dateStrip"></div>
</div>

<!-- Task list -->
<div id="taskList"></div>

<!-- Overdue section -->
<div class="collapsible-section" id="overdueSection">
    <div class="collapsible-header" onclick="toggleSection('overdue')">
        <span class="collapsible-title text-danger">
            <i class="ki-outline ki-time -2 fs-5 me-2 text-danger"></i>@_localizer["Overdue"]
            <span class="badge badge-light-danger ms-2" id="overdueCount" style="display:none"></span>
        </span>
        <i class="ki-outline ki-down fs-5 collapsible-chevron" id="overdueChevron"></i>
    </div>
    <div class="collapsible-body" id="overdueBody">
        <div id="overdueList"></div>
        <button class="load-more-btn" id="overdueMore" style="display:none" onclick="loadMore('overdue')">
            @_localizer["LoadMore"]
        </button>
    </div>
</div>

<!-- Upcoming section -->
<div class="collapsible-section" id="upcomingSection">
    <div class="collapsible-header" onclick="toggleSection('upcoming')">
        <span class="collapsible-title text-primary">
            <i class="ki-outline ki-calendar-tick fs-5 me-2 text-primary"></i>@_localizer["Upcoming"]
            <span class="badge badge-light-primary ms-2" id="upcomingCount" style="display:none"></span>
        </span>
        <i class="ki-outline ki-down fs-5 collapsible-chevron" id="upcomingChevron"></i>
    </div>
    <div class="collapsible-body" id="upcomingBody">
        <div id="upcomingList"></div>
        <button class="load-more-btn" id="upcomingMore" style="display:none" onclick="loadMore('upcoming')">
            @_localizer["LoadMore"]
        </button>
    </div>
</div>

<!-- No-date section -->
<div class="collapsible-section" id="nodateSection">
    <div class="collapsible-header" onclick="toggleSection('nodate')">
        <span class="collapsible-title">
            <i class="ki-outline ki-minus-circle fs-5 me-2 text-muted"></i>@_localizer["NoDeadline"]
        </span>
        <i class="ki-outline ki-down fs-5 collapsible-chevron" id="nodateChevron"></i>
    </div>
    <div class="collapsible-body" id="nodateBody">
        <div id="nodateList"></div>
    </div>
</div>

<!-- Delete modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@_localizer["DeleteTitle"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @_localizer["DeleteConfirm"] "<span id="deleteTaskTitle"></span>"
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@_localizer["Cancel"]</button>
                <button type="button" id="confirmDeleteBtn" class="btn btn-danger">@_localizer["Delete"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $("#tasksMenu").addClass("active");
    const CURRENT_USER_ID = @User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value;
    const NO_ACCESS_HINT = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(_localizer["NoAccess"].Value));

    // ─── State ───────────────────────────────────────────────────────────────
    const DAY_MS = 86400000;
    const today = new Date(); today.setHours(0,0,0,0);
    let activeDate = today;
    let loadedDates = new Set();
    let taskCache = {};

    // ─── Build date strip ────────────────────────────────────────────────────
    const strip = document.getElementById('dateStrip');
    const DAYS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(_localizer["DayNames"].Value.Split(',')));
    const LOCALE = '@System.Globalization.CultureInfo.CurrentCulture.Name';

    const _dayFmt = LOCALE.startsWith('fa')
        ? new Intl.DateTimeFormat('fa-IR-u-ca-persian', { day: 'numeric' })
        : null;

    function chipDate(d) {
        return _dayFmt ? _dayFmt.format(d) : d.getDate();
    }

    function buildStrip() {
        strip.innerHTML = '';
        for (let i = -30; i <= 30; i++) {
            const d = new Date(today.getTime() + i * DAY_MS);
            const chip = document.createElement('div');
            chip.className = 'date-chip' + (i === 0 ? ' active' : '');
            chip.dataset.date = toIso(d);
            chip.innerHTML = `
                <span class="chip-day">${DAYS[d.getDay()]}</span>
                <span class="chip-date">${chipDate(d)}</span>
                <span class="chip-dot" style="visibility:hidden" id="dot-${toIso(d)}"></span>`;
            chip.addEventListener('click', () => selectDate(d));
            strip.appendChild(chip);
        }
        // Scroll today into center
        const todayChip = strip.querySelector('.active');
        if (todayChip) todayChip.scrollIntoView({ inline: 'center', behavior: 'instant' });
    }

    // ─── Select date ─────────────────────────────────────────────────────────
    function selectDate(date) {
        activeDate = date;
        strip.querySelectorAll('.date-chip').forEach(c => c.classList.remove('active'));
        const chip = strip.querySelector(`[data-date="${toIso(date)}"]`);
        if (chip) { chip.classList.add('active'); chip.scrollIntoView({ inline: 'center', behavior: 'smooth' }); }
        loadDateTasks(date);
    }

    // ─── Load tasks for date ──────────────────────────────────────────────────
    function loadDateTasks(date) {
        const iso = toIso(date);
        if (taskCache[iso]) { renderDateTasks(taskCache[iso]); return; }

        document.getElementById('taskList').innerHTML = `
            <div class="tasks-skeleton">
                <div class="sk-line" style="width:70%"></div>
                <div class="sk-line" style="width:50%"></div>
                <div class="sk-line" style="width:60%"></div>
            </div>`;

        $.get(`/api/tasks/by-date?date=${iso}`, function(tasks) {
            taskCache[iso] = tasks;
            renderDateTasks(tasks);
            // Show dot if has tasks
            const dot = document.getElementById(`dot-${iso}`);
            if (dot && tasks.length > 0) dot.style.visibility = 'visible';
        });
    }

    function renderDateTasks(tasks) {
        const list = document.getElementById('taskList');
        if (!tasks.length) {
            list.innerHTML = `<div class="empty-day"><i class="ki-outline ki-calendar"></i>@_localizer["NoTasksToday"]</div>`;
            return;
        }
        list.innerHTML = tasks.map(taskHtml).join('');
    }

    // ─── Load no-date tasks ───────────────────────────────────────────────────
    function loadNodateTasks() {
        const list = document.getElementById('nodateList');
        list.innerHTML = skeletonHtml();
        $.get('/api/tasks/no-date', function(tasks) {
            sections.nodate.loaded = true;
            list.innerHTML = tasks.length
                ? tasks.map(taskHtml).join('')
                : `<div class="text-muted fs-7 px-4 py-3">@_localizer["NoTasks"]</div>`;
        });
    }

    // ─── Task HTML ────────────────────────────────────────────────────────────
    function taskHtml(t) {
        console.log(t)
        const done = t.status;
        const overdue = t.deadLine && new Date(t.deadLine) < today && !done;
        const meta = [
            t.project ? `<i class="ki-outline ki-element-11 fs-8 me-1"></i>${t.project.title}` : '',
            t.group   ? `<i class="ki-outline ki-people fs-8 me-1"></i>${t.group.title}` : '',
            overdue   ? `<span class="text-danger">@_localizer["Overdue"]</span>` : ''
        ].filter(Boolean).join(' &nbsp;·&nbsp; ');

        return `<div class="task-item" id="task-${t.id}">
            <div class="task-check ${done ? 'done' : ''}" onclick="toggleStatus(${t.id}, this)"></div>
            <div class="flex-grow-1 overflow-hidden">
                <div class="task-title fw-semibold text-truncate ${done ? 'done' : ''}">${escHtml(t.title)}</div>
                ${meta ? `<div class="task-meta mt-1">${meta}</div>` : ''}
            </div>
            <div class="task-actions">
                ${t.creatorId === CURRENT_USER_ID ? `
                <a href="/Dashboard/TaskForm?id=${t.id}" class="btn btn-icon btn-sm btn-light-primary">
                    <i class="ki-outline ki-pencil fs-5"></i>
                </a>
                <button class="btn btn-icon btn-sm btn-light-danger" onclick="showDeleteModal(${t.id}, '${escJs(t.title)}')">
                    <i class="ki-outline ki-trash fs-5"></i>
                </button>` : `
                <button class="btn btn-icon btn-sm btn-light-secondary" disabled title="${NO_ACCESS_HINT}">
                    <i class="ki-outline ki-lock fs-5"></i>
                </button>`}
            </div>
        </div>`;
    }

    // ─── Toggle status ────────────────────────────────────────────────────────
    function toggleStatus(id, el) {
        const isDone = !el.classList.contains('done');
        el.classList.toggle('done', isDone);
        const titleEl = el.closest('.task-item').querySelector('.task-title');
        titleEl.classList.toggle('done', isDone);

        $.ajax({
            url: `/api/tasks/${id}/status`,
            type: 'PATCH',
            error: function() {
                el.classList.toggle('done', !isDone);
                titleEl.classList.toggle('done', !isDone);
            }
        });

        // Invalidate cache for active date so it refreshes next time
        delete taskCache[toIso(activeDate)];
    }

    // ─── Delete ───────────────────────────────────────────────────────────────
    function showDeleteModal(id, title) {
        document.getElementById('deleteTaskTitle').textContent = title;
        document.getElementById('confirmDeleteBtn').onclick = () => deleteTask(id);
        $('#deleteModal').modal('show');
    }

    function deleteTask(id) {
        $.ajax({
            url: `/api/tasks/${id}`,
            type: 'DELETE',
            success: function() {
                $('#deleteModal').modal('hide');
                document.getElementById(`task-${id}`)?.remove();
                delete taskCache[toIso(activeDate)];
                if (!document.querySelector('#taskList .task-item')) {
                    document.getElementById('taskList').innerHTML =
                        `<div class="empty-day"><i class="ki-outline ki-calendar"></i>@_localizer["NoTasksToday"]</div>`;
                }
            },
            error: function() { toastr.error('@_localizer["ErrDeleteTask"]'); }
        });
    }

    // ─── Utils ────────────────────────────────────────────────────────────────
    function toIso(d) {
        const m = String(d.getMonth()+1).padStart(2,'0');
        const day = String(d.getDate()).padStart(2,'0');
        return `${d.getFullYear()}-${m}-${day}`;
    }
    function escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function escJs(s) { return s.replace(/\\/g,'\\\\').replace(/'/g,"\\'"); }

    // ─── Collapsible sections ─────────────────────────────────────────────────
    const sections = {
        overdue:  { page: 1, loaded: false, hasMore: false, cache: [] },
        upcoming: { page: 1, loaded: false, hasMore: false, cache: [] },
        nodate:   { loaded: false, cache: [] }
    };

    function toggleSection(key) {
        const suffix  = key === 'nodate' ? 'nodate' : key;
        const body    = document.getElementById(suffix + 'Body');
        const chevron = document.getElementById(suffix + 'Chevron');
        const isOpen  = body.classList.contains('open');

        body.classList.toggle('open', !isOpen);
        chevron.classList.toggle('open', !isOpen);

        if (!isOpen && !sections[key].loaded) {
            if (key === 'nodate') loadNodateTasks();
            else loadSection(key);
        }
    }

    function skeletonHtml() {
        return `<div class="tasks-skeleton px-4 py-3">
            <div class="sk-line" style="width:65%"></div>
            <div class="sk-line" style="width:40%"></div>
        </div>`;
    }

    function renderSection(key) {
        const s       = sections[key];
        const list    = document.getElementById(key + 'List');
        const moreBtn = document.getElementById(key + 'More');
        const countEl = document.getElementById(key + 'Count');

        list.innerHTML = s.cache.length
            ? s.cache.map(taskHtml).join('')
            : `<div class="text-muted fs-7 px-4 py-3">@_localizer["NoTasks"]</div>`;

        if (countEl) {
            countEl.textContent = s.hasMore ? s.cache.length + '+' : s.cache.length || '';
            countEl.style.display = s.cache.length ? '' : 'none';
        }
        moreBtn.style.display = s.hasMore ? 'block' : 'none';
    }

    function loadSection(key) {
        const s    = sections[key];
        const list = document.getElementById(key + 'List');
        list.innerHTML = skeletonHtml();

        $.get(`/api/tasks/${key}?page=1&pageSize=10`, function(res) {
            s.loaded  = true;
            s.hasMore = res.hasMore;
            s.page    = 2;
            s.cache   = res.items;
            renderSection(key);
        });
    }

    function loadMore(key) {
        const s       = sections[key];
        const moreBtn = document.getElementById(key + 'More');
        moreBtn.disabled = true;
        moreBtn.textContent = '...';

        $.get(`/api/tasks/${key}?page=${s.page}&pageSize=10`, function(res) {
            s.page++;
            s.hasMore = res.hasMore;
            s.cache.push(...res.items);
            document.getElementById(key + 'List').insertAdjacentHTML('beforeend', res.items.map(taskHtml).join(''));
            moreBtn.disabled = false;
            moreBtn.textContent = '@_localizer["LoadMore"]';
            moreBtn.style.display = res.hasMore ? 'block' : 'none';

            const countEl = document.getElementById(key + 'Count');
            if (countEl) {
                countEl.textContent = s.hasMore ? s.cache.length + '+' : s.cache.length;
            }
        });
    }

    // ─── Init ─────────────────────────────────────────────────────────────────
    buildStrip();
    loadDateTasks(today);
</script>
}
