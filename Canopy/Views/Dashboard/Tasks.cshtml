@namespace Canopy.Resources
@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization 

@using Canopy.Models
@model List<PlannedTask>

@inject IViewLocalizer _localizer

@{
    Layout = "~/views/Shared/_DashboardLayout.cshtml";


}

<div class="toolbar d-flex justify-content-between mb-5">
    <h3>@_localizer["TableTitle"]</h3>
    <a href="/Dashboard/TaskForm" class="btn btn-primary">
        <i class="ki-outline ki-plus fs-2"></i> @_localizer["NewTaskTitle"]
    </a>
</div>

<table id="tasksTable" class="table table-row-dashed table-hover">
    <thead>
        <tr class="fw-bold text-muted">
            <th>@_localizer["TitleColumn"]</th>
            <th>@_localizer["StatusColumn"]</th>
            <th>@_localizer["DeadlineColumn"]</th>
            <th class="text-end">@_localizer["ActionsColumn"]</th>
        </tr>
    </thead>
    <tbody id="taskTableBody">
        @if (!Model.Any())
        {
            <tr>
                <td colspan="4" class="text-center py-10">
                    <div class="text-muted">
                        <i class="ki-outline ki-element-11 fs-2tx mb-3"></i>
                        <p>@_localizer["NoTasks"]</p>
                        <a href="/Dashboard/TaskForm" class="btn btn-sm btn-primary">@_localizer["AddFirstTask"]</a>
                    </div>
                </td>
            </tr>
        }
        @foreach (var task in Model)
        {
            <tr>
                <td>
                    <span class="fw-bold">@task.Title</span>
                    @if (!string.IsNullOrEmpty(task.Description))
                    {
                        <br />
                        <small class="text-muted">@task.Description</small>
                    }
                </td>
                <td>
                    <div class="d-flex align-items-center gap-3">
                        <div class="status-cell">
                            @if (task.Status)
                            {
                                <span class="badge badge-light-success fs-7">
                                    <i class="ki-outline ki-check-circle fs-6 me-1"></i> @_localizer["Done"]
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-light-warning fs-7">
                                    <i class="ki-outline ki-information fs-6 me-1"></i> @_localizer["Pending"]
                                </span>
                            }
                        </div>
                        <input type="checkbox"
                               class="form-check-input task-status-check"
                               data-task-id="@task.Id"
                               @(task.Status ? "checked" : "")
                               onchange="toggleTaskStatus(this)" />
                    </div>
                </td>
                <td>
                    @if (task.DeadLine.HasValue)
                    {
                        var isOverdue = task.DeadLine.Value.Date < DateTime.Now.Date && !task.Status;
                        <span class="@(isOverdue ? "text-danger fw-bold" : "")">
                            <i class="ki-outline ki-calendar fs-6 me-1"></i>
                            @task.DeadLine.Value.ToString("MMM dd, yyyy")
                            @if (isOverdue)
                            {
                                <span class="badge badge-light-danger fs-8 ms-2">@_localizer["Overdue"]</span>
                            }
                            @if (task.DeadLine.Value.Date == DateTime.Today)
                            {
                                <span class="badge badge-light-warning fs-8 ms-2">@_localizer["Today"]</span>
                            }
                        </span>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
                <td class="text-end">
                    <a href="/Dashboard/TaskForm?id=@task.Id"
                       class="btn btn-sm btn-icon btn-light-primary me-1"
                       data-bs-toggle="tooltip" title="@_localizer["Edit"]">
                        <i class="ki-outline ki-pencil fs-2"></i>
                    </a>
                    <a class="btn btn-sm btn-icon btn-light-danger"
                       data-bs-toggle="tooltip" title="@_localizer["Delete"]"
                       onclick="showDeleteModal(@task.Id, '@task.Title')">
                        <i class="ki-outline ki-trash fs-2"></i>
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @_localizer["DeleteConfirm"] "<span id="deleteTaskTitle"></span>"
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@_localizer["Cancel"]</button>
                <a href="#" id="confirmDeleteBtn" class="btn btn-danger">@_localizer["Delete"]</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $("#tasksMenu").addClass("active");

        function showDeleteModal(id, title) {
            $('#deleteTaskTitle').text(title);
            $('#confirmDeleteBtn').attr('onclick', 'deleteTask(' + id + ')' );
            $('#deleteModal').modal('show');
        }

        function deleteTask(id) {
                console.log("hello?")
                $.ajax({
                    url: '/api/tasks/' + id,
                    type: 'DELETE',
                    success: function() {
                        location.reload();
                    },
                    error: function() {
                        toastr.error('Failed to delete task');
                    }
                });
        }

        function toggleTaskStatus(checkbox) {
            var taskId = $(checkbox).data('task-id');
            var isDone = $(checkbox).is(':checked');

            var $row = $(checkbox).closest('td');
            var $statusCell = $row.find('.status-cell');

            $statusCell.html('<span class="badge badge-light-info">...</span>');

            $.ajax({
                url: '/api/tasks/' + taskId + '/status',
                type: 'PATCH',
                contentType: 'application/json',
                 success: function() {
                    if (isDone) {
                        $statusCell.html(`
                            <span class="badge badge-light-success fs-7">
                                <i class="ki-outline ki-check-circle fs-6 me-1"></i> @_localizer["Pending"]
                            </span>
                        `);
                    } else {
                        $statusCell.html(`
                            <span class="badge badge-light-warning fs-7">
                                <i class="ki-outline ki-information fs-6 me-1"></i> @_localizer["Done"]
                            </span>
                        `);
                    }
                },
                error: function() {
                    $(checkbox).prop('checked', !isDone);
                }
            });
        }
    </script>
}