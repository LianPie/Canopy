@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization

@inject IViewLocalizer V
@inject IHtmlLocalizer<SharedResources> SR
@{
    Layout = "_Layout.cshtml";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isRTL = requestCulture?.RequestCulture.Culture.Name == "fa";
}
@section Head {

    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Inter:300,400,500,600,700" />
    <link rel="stylesheet" href="~/css/notyf.min.css" />
    @if (isRTL)
    {
        <link href="~/css/bootstrap.rtl.min.css" rel="stylesheet" />
        <link href="~/css/style.bundle.rtl.css" rel="stylesheet" />
        <link href="~/datatables/datatables.bundle.rtl.css" rel="stylesheet" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/persian-datepicker@1.2.0/dist/css/persian-datepicker.min.css" />


    }
    else
    {
        <link href="~/css/bootstrap.min.css" rel="stylesheet" />
        <link href="~/datatables/datatables.bundle.css" rel="stylesheet" />
        <link href="~/css/style.bundle.css" rel="stylesheet" />

    }
    <style>
        #toastr-container > .toastr {
            opacity: 1;
        }

        div.dataTables_length + div.dataTables_info {
            margin-right: 1rem;
            margin-left: 0;
        }

        table.dataTable thead th,
        table.dataTable thead td,
        table.dataTable tfoot th,
        table.dataTable tfoot td,
        table.dataTable td,
        table.dataTable th {
            text-align: center;
        }

        table.dataTable > thead .sorting_asc:before,
        table.dataTable > thead .sorting_asc:after,
        table.dataTable > thead .sorting_desc:before,
        table.dataTable > thead .sorting_desc:after {
            margin-right: 0.5rem;
            margin-left: 0;
        }

        .select2-container--bootstrap5 .select2-dropdown .select2-results__option.select2-results__option--selected {
            padding-right: 30px !important;
        }

        .select2-container--bootstrap5 .select2-selection--multiple:not(.form-select-sm):not(.form-select-lg) .select2-selection__choice .select2-selection__choice__display {
            margin-right: 1.1rem;
            margin-left: 0;
        }

        .select2-container--bootstrap5 .select2-selection--multiple:not(.form-select-sm):not(.form-select-lg) .select2-selection__choice {
            margin-left: 0.5rem;
            margin-right: 0;
        }

        .select2-container--bootstrap5 .select2-selection__clear {
            left: 3rem;
            right: auto;
        }

        .form-check-custom .form-check-label {
            margin-left: 0.55rem;
        }

        tr {
            vertical-align: middle;
        }

        .ck-reset_all :not(.ck-reset_all-excluded *),
        .ck.ck-reset_all {
            font-family: 'IRANSansWeb';
        }

        #kt_docs_ckeditor_document {
            border: 1px solid var(--bs-gray-300) !important;
        }

        @@keyframes skeleton-pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }
        .notif-skeleton .skeleton-line,
        .notif-skeleton .skeleton-circle {
            animation: skeleton-pulse 1.4s ease-in-out infinite;
        }

        .wave {
            background-color: #F3F6F9;
            overflow: hidden;
            position: relative;
        }

            .wave > div {
                z-index: 1;
            }

            .wave:before {
                content: ' ';
                position: absolute;
                top: 0;
                right: 0;
                left: 0;
                bottom: 0;
                background-color: #ffffff;
                z-index: -1;
            }

            .wave:after {
                content: ' ';
                width: 1000px;
                height: 1025px;
                position: absolute;
                bottom: 65%;
                right: -250px;
                border-radius: 35%;
                background: var(--wave-color);
                z-index: 0;
            }

            .wave:after {
                -webkit-transform: rotate(-45deg);
                transform: rotate(-45deg);
            }

        .wave-animate:after {
            -webkit-animation: animate-wave 15s infinite linear;
            animation: animate-wave 15s infinite linear;
        }

        .wave-animate-slower:after {
            -webkit-animation: animate-wave 30s infinite linear;
            animation: animate-wave 30s infinite linear;
        }

        .wave-animate-slow:after {
            -webkit-animation: animate-wave 25s infinite linear;
            animation: animate-wave 25s infinite linear;
        }

        .wave-animate-fast:after {
            -webkit-animation: animate-wave 10s infinite linear;
            animation: animate-wave 10s infinite linear;
        }

        .wave-animate-faster:after {
            -webkit-animation: animate-wave 5s infinite linear;
            animation: animate-wave 5s infinite linear;
        }

        .wave.wave-primary {
            background-color: rgba(13, 55, 21, 0.1) !important;
        }

            .wave.wave-primary .svg-icon svg g [fill] {
                fill: #3699FF;
            }

        .wave.wave-secondary {
            background-color: rgba(228, 230, 239, 0.1) !important;
        }

            .wave.wave-secondary .svg-icon svg g [fill] {
                fill: #E4E6EF;
            }

        .wave.wave-success {
            background-color: rgba(27, 197, 189, 0.1) !important;
        }

            .wave.wave-success .svg-icon svg g [fill] {
                fill: #1BC5BD;
            }

        .wave.wave-info {
            background-color: rgba(137, 80, 252, 0.1) !important;
        }

            .wave.wave-info .svg-icon svg g [fill] {
                fill: #8950FC;
            }

        .wave.wave-warning {
            background-color: rgba(255, 168, 0, 0.1) !important;
        }

            .wave.wave-warning .svg-icon svg g [fill] {
                fill: #FFA800;
            }

        .wave.wave-danger {
            background-color: rgba(246, 78, 96, 0.1) !important;
        }

            .wave.wave-danger .svg-icon svg g [fill] {
                fill: #F64E60;
            }

        .wave.wave-light {
            background-color: rgba(243, 246, 249, 0.1) !important;
        }

            .wave.wave-light .svg-icon svg g [fill] {
                fill: #F3F6F9;
            }

        .wave.wave-dark {
            background-color: rgba(24, 28, 50, 0.1) !important;
        }

            .wave.wave-dark .svg-icon svg g [fill] {
                fill: #181C32;
            }

        .wave.wave-white {
            background-color: rgba(255, 255, 255, 0.1) !important;
        }

            .wave.wave-white .svg-icon svg g [fill] {
                fill: #ffffff;
            }

        @@-webkit-keyframes animate-wave {
            from {
                -webkit-transform: rotate(0deg);
                transform: rotate(0deg);
            }

            to {
                -webkit-transform: rotate(-360deg);
                transform: rotate(-360deg);
            }
        }

        @@keyframes animate-wave {
            from {
                -webkit-transform: rotate(0deg);
                transform: rotate(0deg);
            }

            to {
                -webkit-transform: rotate(-360deg);
                transform: rotate(-360deg);
            }
        }
    </style>
}
