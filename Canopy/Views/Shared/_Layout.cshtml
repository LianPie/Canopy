@using Microsoft.AspNetCore.Localization
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var isRTL = requestCulture?.RequestCulture.Culture.Name == "fa";
}
<!DOCTYPE html>
<html lang="@requestCulture?.RequestCulture.Culture.Name" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <script>
        var t = localStorage.getItem('data-bs-theme') || 'dark';
        document.documentElement.setAttribute('data-bs-theme', t);
        localStorage.setItem('data-bs-theme', t);
        localStorage.setItem('data-bs-theme-mode', t);
    </script>
    <style>
        html[data-kt-theme-mode-switching] *, html[data-kt-theme-mode-switching] *::before, html[data-kt-theme-mode-switching] *::after {
            transition: none !important;
        }
    </style>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Canopy</title>
    <script type="importmap"></script>


    @if (isRTL)
    {
        <link href="~/css/plugins.bundle.rtl.css" rel="stylesheet" />
    }

    else
    {
        <link href="~/css/plugins.bundle.css" rel="stylesheet" />
    }

    @await RenderSectionAsync("Head", required: false)
    @if (isRTL)
    {
        <link href="~/css/rtl.css" rel="stylesheet" />
    }
    <link href="~/css/stylecolors.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.4/toastr.min.css" rel="stylesheet" />
</head>
<body>

    @RenderBody()

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/plugins.bundle.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.4/toastr.min.js"></script>


    <script>
        toastr.options = {
            "closeButton": true,
            "debug": false,
            "newestOnTop": true,
            "progressBar": true,
            "positionClass": "toastr-top-left",
            "preventDuplicates": false,
            "showDuration": 300,
            "hideDuration": 1000,
            "timeOut": 5000,
            "extendedTimeOut": 1000,
            "showEasing": "swing",
            "hideEasing": "linear",
            "showMethod": "fadeIn",
            "hideMethod": "fadeOut",
            "tapToDismiss": true
        };

        $(document).ready(function () {
            // 1. Check if the URL has a culture parameter
            const urlParams = new URLSearchParams(window.location.search);
            const culture = urlParams.get('culture');

            if (culture) {
                // 2. Format the cookie value ASP.NET Core expects
                // Format: c=en|uic=en (c = Culture, uic = UI Culture)
                const cookieValue = `c=${culture}|uic=${culture}`;

                // 3. Save the cookie (Expires in 1 year)
                const date = new Date();
                date.setTime(date.getTime() + (365 * 24 * 60 * 60 * 1000));
                document.cookie = `.AspNetCore.Culture=${cookieValue}; expires=${date.toUTCString()}; path=/`;

                console.log("Language saved: " + culture);
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

